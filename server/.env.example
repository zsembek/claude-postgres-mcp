# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required: Public URL where this server is reachable (no trailing slash)
# Must be HTTPS in production for OAuth to work from Claude Code
SERVER_URL=https://pg-mcp.yourdomain.com

# Required: Secret for signing JWT tokens (generate with: openssl rand -base64 32)
JWT_SECRET=replace-with-a-long-random-string

# Required: Admin token shown in server logs on first start.
# If not set, a random token is generated at startup and printed to stdout.
# Set this to a fixed value so it survives container restarts.
ADMIN_TOKEN=replace-with-a-secure-token

# Optional
MAX_ROWS=1000
PORT=8000
